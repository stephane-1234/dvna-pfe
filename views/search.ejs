<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DVNA-PFE — Recherche</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>
<main class="main-content">

  <div class="card">
    <div class="card-header">
      <div>
        <div class="page-title">Recherche d'utilisateurs</div>
        <div class="page-subtitle">Recherchez un utilisateur par nom</div>
      </div>
      <span class="vuln-badge">XSS — DAST / ZAP</span>
    </div>

    <div class="alert alert-warn">
      <strong>VULN-02 :</strong> La valeur recherchee est affichee avec <code>&lt;%-&gt;</code> (non echappe) en EJS.<br>
      Essayez : <code>&lt;script&gt;alert('XSS')&lt;/script&gt;</code>
    </div>

    <form method="GET" action="/search">
      <div class="form-group">
        <label>Rechercher un utilisateur</label>
        <input type="text" name="q" value="<%= query %>" placeholder="ex: admin">
      </div>
      <button type="submit" class="btn btn-primary">Rechercher</button>
    </form>

    <% if (query) { %>
      <div style="margin-top:20px; font-size:13px; color:var(--text-dim);">
        Resultats pour : <strong style="color:#fff;"><%- query %></strong>
      </div>
      <table style="margin-top:10px;">
        <thead>
          <tr><th>ID</th><th>Utilisateur</th><th>Role</th></tr>
        </thead>
        <tbody>
          <% result.forEach(u => { %>
            <tr>
              <td><%= u.id %></td>
              <td><%= u.username %></td>
              <td><%= u.role %></td>
            </tr>
          <% }) %>
          <% if (result.length === 0) { %>
            <tr><td colspan="3" style="color:var(--text-dim);">Aucun resultat</td></tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card">
    <div style="font-size:12px; color:var(--text-dim); font-weight:500; text-transform:uppercase; letter-spacing:.04em; margin-bottom:12px;">Code vulnerable — views/search.ejs</div>
    <div class="terminal-output" style="color:var(--yellow);">// VULNERABLE — <%- %> n'echappe pas le HTML
Resultats pour : &lt;%- query %&gt;</div>
    <div style="margin-top:12px; padding:12px 16px; background:rgba(45,186,114,.07); border:1px solid rgba(45,186,114,.2); border-radius:5px;">
      <div style="font-size:12px; color:var(--green); font-weight:500; margin-bottom:6px;">CORRECTION</div>
      <div class="terminal-output" style="margin-top:0; color:var(--green);">// Utiliser <%= %> qui echappe automatiquement le HTML
Resultats pour : &lt;%= query %&gt;</div>
    </div>
  </div>

</main>
<%- include('partials/footer') %>
</body>
</html>