<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DVNA-PFE — Deserialisation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>
<main class="main-content">

  <div class="card">
    <div class="card-header">
      <div>
        <div class="page-title">Deserialisation</div>
        <div class="page-subtitle">Parsing securise de donnees JSON</div>
      </div>
      <span class="vuln-badge" style="background:rgba(45,186,114,.15);border-color:rgba(45,186,114,.3);color:#2dba72;">CVE node-serialize — CORRIGE</span>
    </div>

    <div class="alert alert-success">
      <strong>FIX-04 :</strong> <code>node-serialize</code> a ete supprime du projet.<br>
      Seul <code>JSON.parse()</code> est utilise — aucune execution de code possible.
    </div>

    <form method="POST" action="/deserialize">
      <div class="form-group">
        <label>Payload JSON a parser</label>
        <textarea name="payload" rows="4" placeholder='{"username":"alice","role":"user"}'></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Parser (JSON securise)</button>
    </form>

    <% if (result) { %>
      <div class="terminal-output"><%= result %></div>
    <% } %>
  </div>

  <div class="card">
    <div style="font-size:12px; color:var(--text-dim); font-weight:500; text-transform:uppercase; letter-spacing:.04em; margin-bottom:12px;">Correction appliquee — server.js + package.json</div>
    <div class="terminal-output" style="color:var(--yellow);">// AVANT (vulnerable)
const serialize = require('node-serialize'); // CVE CVSS 9.8
const data = serialize.unserialize(req.body.payload); // RCE possible</div>
    <div style="margin-top:12px; padding:12px 16px; background:rgba(45,186,114,.07); border:1px solid rgba(45,186,114,.2); border-radius:5px;">
      <div style="font-size:12px; color:var(--green); font-weight:500; margin-bottom:6px;">APRES (corrige)</div>
      <div class="terminal-output" style="margin-top:0; color:var(--green);">// node-serialize retire du package.json
// JSON.parse() uniquement — pas d'execution de code
const data = JSON.parse(req.body.payload);</div>
    </div>
  </div>

</main>
<%- include('partials/footer') %>
</body>
</html>
